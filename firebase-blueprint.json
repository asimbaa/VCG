{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the banking application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "balances": {
          "type": "object",
          "description": "Map of currency codes to balance amounts."
        }
      },
      "required": ["uid", "email", "balances"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "recipient": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] }
      },
      "required": ["userId", "date", "amount", "currency", "recipient", "type", "status"]
    },
    "SavedRecipient": {
      "title": "SavedRecipient",
      "description": "A saved transfer recipient.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "recipient": { "type": "string" },
        "region": { "type": "string" },
        "payIdType": { "type": "string" },
        "cardName": { "type": "string" },
        "cardExpiry": { "type": "string" }
      },
      "required": ["userId", "name", "type", "recipient"]
    },
    "RecurringTransfer": {
      "title": "RecurringTransfer",
      "description": "A recurring transfer setup.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "client": { "type": "string" },
        "service": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "frequency": { "type": "string" }
      },
      "required": ["userId", "client", "service", "amount", "currency", "frequency"]
    },
    "FundingSource": {
      "title": "FundingSource",
      "description": "A funding source for deposits.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "name": { "type": "string" },
        "details": { "type": "string" },
        "institution": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "name", "details", "institution", "createdAt"]
    },
    "DraftTransaction": {
      "title": "DraftTransaction",
      "description": "A draft transaction saved by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "transferType": { "type": "string" },
        "amount": { "type": "string" },
        "transferCurrency": { "type": "string" },
        "recipient": { "type": "string" },
        "region": { "type": "string" },
        "cardName": { "type": "string" },
        "cardExpiry": { "type": "string" },
        "payIdType": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "updatedAt"]
    },
    "BrandAsset": {
      "title": "BrandAsset",
      "description": "An asset owned by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "owner": { "type": "string" }
      },
      "required": ["userId", "createdAt", "name", "type", "status", "owner"]
    },
    "DriverRating": {
      "title": "DriverRating",
      "description": "Post-ride rating and feedback for the driver.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "driverName": { "type": "string" },
        "rating": { "type": "number" },
        "feedback": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "driverName", "rating", "createdAt"]
    },
    "FavoriteRoute": {
      "title": "FavoriteRoute",
      "description": "A saved address pair frequently used by the client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "pickup", "destination", "createdAt"]
    },
    "ScheduledRide": {
      "title": "ScheduledRide",
      "description": "A scheduled future trip intent.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "pickupCoords": { "type": "object" },
        "destCoords": { "type": "object" },
        "vehicleType": { "type": "string" },
        "scheduledTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "pickup", "destination", "vehicleType", "scheduledTime", "status", "createdAt"]
    },
    "CompletedTrip": {
      "title": "CompletedTrip",
      "description": "A completed trip record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "distance": { "type": "string" },
        "cost": { "type": "number" },
        "driverName": { "type": "string" },
        "carModel": { "type": "string" }
      },
      "required": ["userId", "pickup", "destination", "startTime", "endTime", "distance", "cost"]
    },
    "EmergencyContact": {
      "title": "EmergencyContact",
      "description": "An emergency contact SOS coordinates payload.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "driverName": { "type": "string" },
        "carModel": { "type": "string" },
        "license": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "timestampMs": { "type": "number" }
      },
      "required": ["userId", "latitude", "longitude", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and balances."
    },
    "/emergency_contacts/{contactId}": {
      "schema": { "$ref": "#/entities/EmergencyContact" },
      "description": "SOS emergency alerts dispatched with coordinates."
    },
    "/completed_trips/{tripId}": {
      "schema": { "$ref": "#/entities/CompletedTrip" },
      "description": "Trip history containing details of all completed rides."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Transaction history."
    },
    "/saved_recipients/{recipientId}": {
      "schema": { "$ref": "#/entities/SavedRecipient" },
      "description": "Saved recipients for easy transfers."
    },
    "/recurring_transfers/{transferId}": {
      "schema": { "$ref": "#/entities/RecurringTransfer" },
      "description": "Recurring transfers."
    },
    "/funding_sources/{sourceId}": {
      "schema": { "$ref": "#/entities/FundingSource" },
      "description": "Funding sources."
    },
    "/draft_transactions/{draftId}": {
      "schema": { "$ref": "#/entities/DraftTransaction" },
      "description": "Draft transactions saved by users."
    },
    "/brand_assets/{assetId}": {
      "schema": { "$ref": "#/entities/BrandAsset" },
      "description": "Brand assets / properties owned by users."
    },
    "/driver_ratings/{ratingId}": {
      "schema": { "$ref": "#/entities/DriverRating" },
      "description": "Post-trip feedback and rating for a vehicle partner."
    },
    "/favorite_routes/{routeId}": {
      "schema": { "$ref": "#/entities/FavoriteRoute" },
      "description": "Frequent pickup/destination route address pairs."
    },
    "/scheduled_rides/{rideId}": {
      "schema": { "$ref": "#/entities/ScheduledRide" },
      "description": "Scheduled ride reservation entries."
    },
    "/scheduled_ride/{rideId}": {
      "schema": { "$ref": "#/entities/ScheduledRide" },
      "description": "Scheduled ride reservation entries alias."
    }
  }
}
