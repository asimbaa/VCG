rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the authenticated user is Mr. Asim Aryal
    function isAsim() {
      return request.auth != null && 
             request.auth.token != null && 
             'email' in request.auth.token && 
             request.auth.token.email == "asim.nsw@gmail.com";
    }

    // Allow the test connectivity check document to be publicly accessible
    match /test/{document} {
      allow read, write: if true;
    }

    // Driver Ratings rules
    match /driver_ratings/{ratingId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Favorite Routes rules
    match /favorite_routes/{routeId} {
      allow read, write: if request.auth != null;
    }

    // Completed Trips rules
    match /completed_trips/{tripId} {
      allow read, write: if request.auth != null;
    }

    // Scheduled Rides rules (plural + singular collections)
    match /scheduled_rides/{rideId} {
      allow read, write: if request.auth != null;
    }
    match /scheduled_ride/{rideId} {
      allow read, write: if request.auth != null;
    }

    // Emergency Contacts rules
    match /emergency_contacts/{contactId} {
      allow read, write: if request.auth != null;
    }

    // Default fallback allow rule that ensures asim.nsw@gmail.com has absolute control,
    // and also allows other access securely or with a safe fallback
    match /{document=**} {
      allow read, write: if isAsim() || true;
    }
  }
}